{
  "name": "@tuwebai/core",
  "version": "0.1.4",
  "description": "Core parser, schema, resolver and generators for the Agent DNA standard.",
  "keywords": ["agent-dna", "ai", "cli", "schema", "developer-tools"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./schema/agent-dna.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Juanchii-Dev/agent-dna",
  "bugs": {
    "url": "https://github.com/Juanchii-Dev/agent-dna/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Juanchii-Dev/agent-dna.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tuwebai/types": "0.1.4",
    "ajv": "^8.17.1",
    "yaml": "^2.8.1"
  },
  "scripts": {
    "build": "npx tsup src/index.ts --format esm --dts --clean --external yaml --external ajv --tsconfig ../../tsconfig.app.json"
  }
}
