{
  "name": "@agent-dna/core",
  "version": "0.1.15",
  "description": "Core parser, schema, resolver and generators for the Agent DNA standard.",
  "keywords": ["agent-dna", "ai", "cli", "schema", "developer-tools"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./schema": "./schema/agent-dna.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Juanchii-Dev/agent-dna",
  "bugs": {
    "url": "https://github.com/Juanchii-Dev/agent-dna/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Juanchii-Dev/agent-dna.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@agent-dna/types": "0.1.15",
    "ajv": "^8.17.1",
    "yaml": "^2.8.1"
  },
  "scripts": {
    "build": "npx tsup src/index.ts src/browser.ts --format esm --dts --clean --external yaml --external ajv --tsconfig ../../tsconfig.app.json"
  }
}
