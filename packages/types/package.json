  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Juanchii-Dev/agent-dna.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npx tsup src/index.ts --format esm --dts --clean --tsconfig ../../tsconfig.app.json"
