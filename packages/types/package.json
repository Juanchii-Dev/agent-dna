  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Juanchii-Dev/agent-dna",
  "bugs": {
