{
  "name": "agent-dna-demo",
  "private": true,
  "version": "0.1.9",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/demo"
  ],
  "scripts": {
    "cli": "npx tsx packages/cli/src/agent-dna-cli.ts",
    "build:packages": "npm run build --workspaces --if-present",
    "pack:types": "npm pack --dry-run --workspace @agent-dna/types",
    "pack:core": "npm pack --dry-run --workspace @agent-dna/core",
    "pack:cli": "npm pack --dry-run --workspace agent-dna",
    "publish:check": "powershell -Command \"npm run build:packages; npm run pack:types; npm run pack:core; npm run pack:cli\"",
    "dev": "vite --config vite.config.ts",
    "typecheck": "npx tsc -b",
    "build": "powershell -Command \"npm run build:packages; npx vite build --config vite.config.ts\"",
    "test": "npx vitest run",
    "preview": "vite preview --config vite.config.ts"
  },
  "packageManager": "npm@10",
  "dependencies": {
    "ajv": "^8.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
